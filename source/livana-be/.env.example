# ===================================================================
# Backend Environment Variables (for local development)
# Copy this to .env and fill in your actual values
# ===================================================================

#
# ─── Database Configuration ─────────────────────────────────────────
#
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/livana
SPRING_DATASOURCE_USERNAME=livana-user
SPRING_DATASOURCE_PASSWORD=livana-pass

#
# ─── JWT Configuration ──────────────────────────────────────────────
#
SPRING_JWT_SECRET_KEY=your-super-secret-jwt-key-min-256-bits-change-this-in-production
SPRING_JWT_SECRET_KEY_EXPIRATION=3600000
REFRESH_TOKEN_EXPIRATION=604800000
RESET_PASSWORD_TOKEN_EXPIRATION=900000
VERIFICATION_CODE_EXPIRATION=300000

#
# ─── Email Configuration (Gmail) ────────────────────────────────────
#
SUPPORT_EMAIL=your-email@gmail.com
APP_PASSWORD=your-gmail-app-password

#
# ─── Cloudinary Configuration ───────────────────────────────────────
#
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=livana

#
# ─── RabbitMQ Configuration ─────────────────────────────────────────
#
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

#
# ─── VNPay Configuration ────────────────────────────────────────────
#
VNPAY_TMN_CODE=your-vnpay-tmn-code
VNPAY_HASH_SECRET=your-vnpay-hash-secret
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5173/payment/vnpay/callback

#
# ─── Frontend URL ───────────────────────────────────────────────────
#
FRONTEND_URL=http://localhost:5173

#
# ─── Demo Data Seeding ──────────────────────────────────────────────
#
SEED_DEMO_DATA=false

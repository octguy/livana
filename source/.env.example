# ===================================================================
# Environment Variables Template for VPS Deployment
# Copy this to .env and fill in your actual values
# ===================================================================

#
# ─── PostgreSQL ─────────────────────────────────────────────────────
#
POSTGRES_PORT=5432

#
# ─── JWT Configuration ──────────────────────────────────────────────
#
SPRING_JWT_SECRET_KEY=your-super-secret-jwt-key-min-256-bits-change-this-in-production
SPRING_JWT_SECRET_KEY_EXPIRATION=3600000
REFRESH_TOKEN_EXPIRATION=604800000
RESET_PASSWORD_TOKEN_EXPIRATION=900000
VERIFICATION_CODE_EXPIRATION=300000

#
# ─── Email Configuration (Gmail) ────────────────────────────────────
#
SUPPORT_EMAIL=your-email@gmail.com
APP_PASSWORD=your-gmail-app-password

#
# ─── Cloudinary Configuration ───────────────────────────────────────
#
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=livana

#
# ─── RabbitMQ Configuration ─────────────────────────────────────────
#
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

#
# ─── VNPay Configuration ────────────────────────────────────────────
# Register at https://sandbox.vnpayment.vn/devreg/
#
VNPAY_TMN_CODE=your-vnpay-tmn-code
VNPAY_HASH_SECRET=your-vnpay-hash-secret
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Update this to your VPS domain
VNPAY_RETURN_URL=http://your-vps-domain.com/payment/vnpay/callback

#
# ─── Frontend URL ───────────────────────────────────────────────────
# Update this to your VPS domain or IP
#
FRONTEND_URL=http://your-vps-domain.com
VITE_API_URL=http://your-vps-domain.com

#
# ─── Demo Data Seeding ──────────────────────────────────────────────
# Set to true to seed demo data on first run (development only)
#
SEED_DEMO_DATA=false
